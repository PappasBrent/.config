#!/usr/bin/env bash

function complete_typst() {
    case $COMP_CWORD in
        # Autocomplete typst command names for the first argument.
        1)
            local options="compile watch init query fonts help" 
            COMPREPLY=($(compgen -W "$options" -- "$2"))
            ;;
        # For the second, autocomplete the names of any typst files, plus allow
        # recursively searching through directories.
        2)  COMPREPLY=($(compgen -o plusdirs -f -X '!*.typ' -- "$2"))
            ;;
        # Don't autocomplete the third argument.
        *)  ;;
    esac

    return 0
}

# Add basic completions for typst commands.
# -o filenames tells Readline to automatically append / to directory names.
complete -o filenames -F complete_typst typst

# Remove PDFs from Vim's completion list.
complete -f -X '*.pdf' vim

